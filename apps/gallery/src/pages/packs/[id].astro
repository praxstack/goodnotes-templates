---
import Layout from '../../layouts/Layout.astro';
import BlurhashImage from '../../components/BlurhashImage.astro';
import { getCollection, render } from 'astro:content';
import blurhashManifest from '../../data/blurhash-manifest.json';
import themePalette from '../../data/theme-palette.json';
import { SITE } from '../../config/site';

export async function getStaticPaths() {
  const packs = await getCollection('packs');
  return packs.map((pack) => ({ params: { id: pack.data.id }, props: { pack } }));
}

const { pack } = Astro.props;
const { Content } = await render(pack);

const manifest = blurhashManifest as Record<
  string,
  { width: number; height: number; blurhash: string; dataUrl: string }
>;
const entry = manifest[pack.data.id];

// Themes for the Customise swatch picker. All 14 (light + dark pairs,
// same ordering as theme-palette.json which is family → light before dark).
// Each link resolves to /packs/<id>/<theme>.pdf — staged by
// apps/gallery/scripts/copy-pack-themed-pdfs.ts at build time.
//
// If the themed PDF isn't staged (e.g. developer skipped
// `scripts/render-all-pack-themes.ts` locally), the 404 will hit gracefully;
// production builds always ship them. The canonical (unthemed) PDF at
// /packs/<id>.pdf stays as the default Download button above.
const themes = (themePalette as { themes: Array<{ id: string; name: string; palette: Record<string, string> }> }).themes;
---

<Layout
  title={`${pack.data.title} · pretext-templates`}
  description={pack.data.oneLiner}
  ogImage={`/og/${pack.data.id}/bold-tech.png`}
>
  <article class="pack container">
    <nav class="pack__crumb meta" aria-label="breadcrumb">
      <a href="/">home</a>
      <span aria-hidden="true">/</span>
      <a href="/browse">browse</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{pack.data.title}</span>
    </nav>

    <header class="pack__head">
      <p class="meta">
        {pack.data.category} · v{pack.data.version} · est. {pack.data.bylineYear}
      </p>
      <h1>{pack.data.title}</h1>
      <p class="pack__lede">{pack.data.oneLiner}</p>

      <div class="pack__actions">
        <a
          class="pack__download"
          href={`/packs/${pack.data.id}.pdf`}
          download
          data-pack-id={pack.data.id}
        >
          <span class="pack__download-label">Download PDF</span>
          <span class="pack__download-meta">A4 · self-contained · GoodNotes-ready</span>
        </a>
        <a class="pack__npm" href="https://www.npmjs.com/package/@praxlannister/pretext-cli">
          or render your own via <code>npx pretext-templates</code>
        </a>
      </div>
    </header>

    {
      pack.data.heroImage && (
        <figure class="pack__specimen">
          <BlurhashImage
            src={pack.data.heroImage}
            alt={`${pack.data.title} specimen`}
            width={entry?.width ?? 1200}
            height={entry?.height ?? 1600}
            blurhashDataUrl={entry?.dataUrl}
            loading="eager"
          />
        </figure>
      )
    }

    <section class="pack__customise" aria-labelledby="customise-heading">
      <h2 id="customise-heading" class="pack__customise-heading">
        Customise the palette
      </h2>
      <p class="pack__customise-lede">
        Same layout, your colors. Download this pack in any of 14 palettes — 7 families · light & dark.
        Layout, fonts, spacing stay the author's; only colors change.
      </p>
      <div class="pack__themes" role="list">
        {themes.map((theme) => (
          <a
            role="listitem"
            class="theme-chip"
            href={`/packs/${pack.data.id}/${theme.id}.pdf`}
            download
            aria-label={`Download ${pack.data.title} in ${theme.name} palette`}
            data-theme-id={theme.id}
          >
            <span
              class="theme-chip__swatch"
              aria-hidden="true"
              style={`background: ${theme.palette.background}; border-color: ${theme.palette.border};`}
            >
              <span
                class="theme-chip__dot theme-chip__dot--primary"
                style={`background: ${theme.palette.primary};`}
              />
              <span
                class="theme-chip__dot theme-chip__dot--accent"
                style={`background: ${theme.palette.accent};`}
              />
              <span
                class="theme-chip__dot theme-chip__dot--fg"
                style={`background: ${theme.palette.foreground};`}
              />
            </span>
            <span class="theme-chip__name">{theme.name}</span>
          </a>
        ))}
      </div>
      <p class="pack__customise-note meta">
        <strong>Tier 1 · Profile</strong> (CLI · fills your name, dates, medications for the Prax
        Journal pack) · <strong>Tier 2 · Themes</strong> (you are here — pick a palette, download
        PDF) · <strong>Tier 3 · In-browser editor</strong> (future — edit fields, export).
        See <a href={`${SITE.repoUrl}/blob/main/docs/CUSTOMISATION.md`}>docs/CUSTOMISATION.md</a>.
      </p>
    </section>

    <div class="pack__body">
      <Content />
    </div>

    <hr class="rule" />

    <footer class="pack__colophon">
      <p class="meta">Colophon</p>
      <p>
        Typeset in Fraunces & JetBrains Mono. {SITE.license}-licensed. Built with the
        <a href={SITE.repoUrl}>
          @praxlannister/pretext-cli
        </a>.
      </p>
    </footer>
  </article>
</Layout>

<style>
  .pack {
    padding-top: 32px;
    padding-bottom: 64px;
    max-width: 780px;
  }
  .pack__crumb {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
  }
  .pack__crumb a {
    color: var(--ink-quiet);
    text-decoration: none;
  }
  .pack__crumb a:hover {
    color: var(--ink);
  }
  .pack__head h1 {
    margin-top: 12px;
  }
  .pack__lede {
    font-family: var(--italic);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--ink-soft);
    margin-top: 16px;
  }
  .pack__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    margin-top: 24px;
  }
  .pack__download {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 14px 28px;
    border-radius: 6px;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-paper), background var(--dur-fast) var(--ease-paper);
  }
  .pack__download:hover {
    transform: translateY(-1px);
    background: var(--ink-soft);
  }
  .pack__download-label {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.05rem;
  }
  .pack__download-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    opacity: 0.8;
    letter-spacing: 0.04em;
  }
  .pack__npm {
    font-size: 0.95rem;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px dotted var(--ink-whisper);
  }
  .pack__npm code {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--paper-tint, rgba(0, 0, 0, 0.04));
    padding: 1px 6px;
    border-radius: 3px;
  }
  .pack__npm:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }
  .pack__specimen {
    margin: 48px 0;
  }

  /* ─── Customise section (14-theme swatch picker) ─── */
  .pack__customise {
    margin: 48px 0 32px;
    padding: 28px 0 0;
    border-top: 1px solid var(--ink-whisper);
  }
  .pack__customise-heading {
    margin: 0 0 8px;
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 600;
  }
  .pack__customise-lede {
    margin: 0 0 20px;
    font-size: 0.98rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .pack__themes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(156px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .theme-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid var(--ink-whisper);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    background: var(--paper);
    transition: border-color var(--dur-fast) var(--ease-paper),
                transform var(--dur-fast) var(--ease-paper);
  }
  .theme-chip:hover {
    border-color: var(--ink);
    transform: translateY(-1px);
  }
  .theme-chip:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }
  .theme-chip__swatch {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 4px;
    border: 1px solid;
    overflow: hidden;
  }
  .theme-chip__dot {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .theme-chip__dot--primary { top: 6px; left: 6px; }
  .theme-chip__dot--accent { top: 6px; right: 6px; }
  .theme-chip__dot--fg { bottom: 6px; right: 6px; }
  .theme-chip__name {
    font-family: var(--serif);
    font-size: 0.85rem;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pack__customise-note {
    font-size: 0.82rem;
    color: var(--ink-quiet);
    line-height: 1.55;
  }
  .pack__customise-note strong {
    color: var(--ink-soft);
    font-weight: 600;
  }
  .pack__customise-note a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--ink-whisper);
  }
  .pack__customise-note a:hover {
    text-decoration-color: var(--ink);
  }

  .pack__body {
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .pack__body :global(h2) {
    margin-top: 40px;
    margin-bottom: 12px;
  }
  .pack__body :global(ul) {
    padding-left: 20px;
  }
  .pack__body :global(li) {
    margin-bottom: 6px;
  }
  .pack__body :global(blockquote) {
    border-left: 3px solid var(--sage);
    background: var(--sage-tint);
    padding: 12px 20px;
    margin: 20px 0;
    color: var(--ink-soft);
    font-style: italic;
  }
  .pack__colophon {
    margin-top: 48px;
    color: var(--ink-soft);
  }
  .pack__colophon .meta {
    margin-bottom: 8px;
  }
</style>
