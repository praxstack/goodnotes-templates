node_modules/
dist/
*.tgz

# Generated output (use GitHub Releases for pre-built assets)
output/templates/
output/stickers/
output/pages/
output/previews/
output/manifest.json

# Keep output directory structure
!output/.gitkeep

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local

# ═══════════════════════════════════════════════════════════════════════
# PII SAFETY — NEVER COMMIT PRAX'S REAL PROFILE
# ═══════════════════════════════════════════════════════════════════════
# profile.json holds medications, therapist names, and baselines.
# profile.example.json is the committable seed with generic placeholders.
# Addresses G3 (CRITICAL) in docs/plan-eng-review-v4-five-decisions.md.
# ═══════════════════════════════════════════════════════════════════════
packs/journals/prax-journal/profile.json
# Defensive: also block the .bak/.local/.personal suffixes people reach for
# when they copy+edit.
packs/journals/prax-journal/profile.*.json
!packs/journals/prax-journal/profile.example.json

# ═══════════════════════════════════════════════════════════════════════
# STICKER PNGs — regenerated by `npm run build:stickers`
# ═══════════════════════════════════════════════════════════════════════
# The SVG is the source of truth and scales infinitely; PNGs are
# deterministic @4× previews. Keeping them in-tree was adding ~59 MB
# of regenerable bytes. Clone + `npm run build:stickers` recreates
# them in ~8 seconds.
packs/journals/prax-journal/stickers/*/*.png

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Downloaded fonts (regenerated by scripts/download-fonts.ts)
assets/fonts/*.ttf
assets/fonts/*.otf
output/
.superpowers/
.gstack/

# tsc build cache (per-workspace)
packages/*/tsconfig.tsbuildinfo
packages/*/dist/
apps/*/dist/
