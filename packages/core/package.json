{
  "name": "@pretext-templates/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Core rendering pipeline — splice, puppeteer, pdf-postprocess, themes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "puppeteer": "^23.11.1",
    "sharp": "^0.33.5",
    "zod": "3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
