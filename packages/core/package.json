{
  "name": "@pretext-templates/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Core rendering pipeline — splice, puppeteer, pdf-postprocess, themes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "//": "Explicit subpath map (code-review P2-2): every export listed here is public API. Internal modules (png-renderer, packs, puppeteer-renderer internals) stay unreachable so downstream packs don't accidentally couple to them.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./dimensions": {
      "import": "./dist/dimensions.js",
      "types": "./dist/dimensions.d.ts"
    },
    "./splice": {
      "import": "./dist/splice.js",
      "types": "./dist/splice.d.ts"
    },
    "./pdf-splice": {
      "import": "./dist/pdf-splice.js",
      "types": "./dist/pdf-splice.d.ts"
    },
    "./pdf-postprocess": {
      "import": "./dist/pdf-postprocess.js",
      "types": "./dist/pdf-postprocess.d.ts"
    },
    "./puppeteer-renderer": {
      "import": "./dist/puppeteer-renderer.js",
      "types": "./dist/puppeteer-renderer.d.ts"
    },
    "./prax-journal-renderer": {
      "import": "./dist/prax-journal-renderer.js",
      "types": "./dist/prax-journal-renderer.d.ts"
    },
    "./standalone-builder": {
      "import": "./dist/standalone-builder.js",
      "types": "./dist/standalone-builder.d.ts"
    },
    "./svg-renderer": {
      "import": "./dist/svg-renderer.js",
      "types": "./dist/svg-renderer.d.ts"
    },
    "./types/profile": {
      "import": "./dist/types/profile.js",
      "types": "./dist/types/profile.d.ts"
    },
    "./types/registry": {
      "import": "./dist/types/registry.js",
      "types": "./dist/types/registry.d.ts"
    },
    "./utils/locale": {
      "import": "./dist/utils/locale.js",
      "types": "./dist/utils/locale.d.ts"
    },
    "./assets/base.css": "./assets/base.css",
    "./assets/themes/*": "./assets/themes/*"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@types/semver": "7.7.1",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^23.11.1",
    "semver": "7.7.4",
    "sharp": "^0.33.5",
    "zod": "3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
