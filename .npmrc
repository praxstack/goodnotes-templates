# Pin engine enforcement at install time so contributors on older Node
# fail fast instead of shipping a broken build.
engine-strict=true

# F8 note (eng-review Section 9): puppeteer native Chromium.
# npm's default hoist keeps puppeteer at root node_modules/puppeteer which
# is where its internal `./lib/cjs/puppeteer/node/browser-runner.js` looks
# for the Chromium binary — so default hoist is correct. Confirmed Week 1
# on macOS + npm@10 by `find . -maxdepth 4 -name puppeteer`. If a future
# arm64 Docker image (Week 15) breaks puppeteer hoisting, move to pnpm or
# add a per-workspace `dependencies.nohoist` override then.
